# Cerebrovascular Analysis Backend — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for Step 7 report generation)
GEMINI_API_KEY=your_api_key_here

# Optional: Override output directory (default: ./output)
# OUTPUT_DIR=/path/to/output

# Optional: Override temp directory (default: ./temp)
# TEMP_DIR=/path/to/temp
